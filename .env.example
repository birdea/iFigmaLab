# Frontend dev server port (default: 3005)
FRONTEND_PORT=3005

# Proxy server port (default: 3006)
PROXY_PORT=3006

# Figma MCP Proxy Server URL (auto-set by 'npm run dev'; override only when running servers manually)
PROXY_URL=http://localhost:3006

# Figma Desktop App MCP Server URL (default: http://localhost:3845)
FIGMA_MCP_URL=http://localhost:3845

# Override AI system prompt (optional — leave empty to use the built-in default)
# SYSTEM_PROMPT=

# Maximum output tokens for Gemini API (default: 65536)
# MAX_OUTPUT_TOKENS=65536
